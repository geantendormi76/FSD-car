# Copy to .env and replace paths for the local machine.
FSD_ASSETS_DIR=/absolute/path/to/fsd-car/assets
ACADOS_SOURCE_DIR=/absolute/path/to/fsd-car/simulation-env/acados
ISAAC_SIM_PYTHON_SH=/absolute/path/to/isaacsim/python.sh
LD_LIBRARY_PATH=/absolute/path/to/fsd-car/simulation-env/acados/lib:/absolute/path/to/fsd-car/simulation-env/c_generated_code
