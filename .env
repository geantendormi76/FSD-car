# =================================================================
# 🛡️ FSD-car V3.0: 物理主权与资产路径全局配置契约 (Ubuntu 26.04 LTS)
# =================================================================

# 1. 核心资产金库 (模型权重、USD 场景、音频等)
FSD_ASSETS_DIR=/home/zhz/fsd-car/assets

# 2. Acados 求解器 C 源码与动态库路径 (已修正为项目内部路径)
ACADOS_SOURCE_DIR=/home/zhz/fsd-car/simulation-env/acados

# 3. Isaac Sim 物理界沙盒路径 (用于 DORA 节点启动)
ISAAC_SIM_PYTHON_SH=/home/zhz/.local/share/ov/pkg/isaac-sim-4.2.0/python.sh

# 4. 动态链接库搜索路径 (保障 DORA 运行时能找到 acados 和生成的 OCP 求解器)
LD_LIBRARY_PATH=/home/zhz/fsd-car/simulation-env/acados/lib:/home/zhz/fsd-car/simulation-env/c_generated_code
