{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "input": {
    "maxFileSize": 1048576
  },
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "parsableStyle": false,
    "compress": false,
    "headerText": "这是我 FSD-car 项目当前的最新全量源码,当前的我开始打算从零开始自研一套FSD自动驾驶架构，来实现小车的纯视觉下能自动化导航驾驶到目标点位！我的愿景是从成本、效率、速度、安全进行开发",
    "fileSummary": true,
    "directoryStructure": true,
    "files": true,
    "removeComments": false,
    "removeEmptyLines": false,
    "showLineNumbers": false,
    "copyToClipboard": false,
    "includeEmptyDirectories": false,
    "includeFullDirectoryStructure": false
  },
  "include": [
    "**/*.rs",
    "**/*.py",
    "**/Cargo.toml",
    "**/*.md",
    "dora_dataflow.yaml",
    "**/.gitignore"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "**/target/**",
      "**/lib_dylib/**",
      "**/model/**",
      "**/acados/**",
      "**/c_generated_code/**",
      "**/Cargo.lock",
      "**/repomix-output.xml"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}