# =================================================================
# 🛡️ FSD-car V3.0: 纯视觉数字孪生本地零拷贝数据流蓝图 (Ubuntu 26.04 LTS 极致版)
# 架构哲学: 去网关化 | 仿生避障下沉至原生 Python 节点 | 共享内存 0 微秒延迟直通
# =================================================================
nodes:
  # ---------------------------------------------------------------
  # 🌌 1. 物理仿真界 (The Matrix) - Isaac Sim 仿真引擎原生 DORA 节点
  # ---------------------------------------------------------------
  - id: isaac_sim_env
    path: /home/zhz/isaacsim/python.sh
    args: simulation-env/isaac_dora_node.py
    env:
      # 🛡️ 强行透传宿主机的显示环境变量，防止 DORA 隔离导致 Vulkan 找不到设备
      DISPLAY: ${DISPLAY}
      WAYLAND_DISPLAY: ${WAYLAND_DISPLAY}
      XDG_SESSION_TYPE: ${XDG_SESSION_TYPE}
    inputs:
      control_cmd: fast_brain_nmpc/control_cmd
    outputs:
      - xfeat_features
      - obstacle_force

  # ---------------------------------------------------------------
  # ⚡ 2. 快系统：本能避障与规控大脑 (The Fast System - 100Hz)
  # ---------------------------------------------------------------
  - id: fast_brain_nmpc
    path: target/release/fast_brain_node
    build: cargo build -p core-control --release --bin fast_brain_node
    env:
      RUST_LOG: info
      DORA_RUNTIME_TYPE_CHECK: warn
      LD_LIBRARY_PATH: /home/zhz/fsd-car/simulation-env/acados/lib:/home/zhz/fsd-car/simulation-env/c_generated_code
    inputs:
      # 从本地共享内存极速订阅避障势场力
      obstacle_force: isaac_sim_env/obstacle_force
    outputs:
      # 输出运动指令契约 (v, w)
      - control_cmd

  # ---------------------------------------------------------------
  # 🧠 3. 慢系统：拓扑建图与语义大脑 (The Slow System - 1Hz)
  # ---------------------------------------------------------------
  - id: slow_brain_mapper
    path: target/release/slow_brain_node
    build: cargo build -p core-decision --release --bin slow_brain_node
    env:
      RUST_LOG: info
    inputs:
      # 从本地共享内存订阅 XFeat 二进制特征，执行 A* 拓扑寻路与建图
      xfeat_features: isaac_sim_env/xfeat_features
