        let right = project_ground_point(calibration(), 2.0, -0.5).unwrap();
        assert!(left.0 < calibration().cx);
        assert!(right.0 > calibration().cx);
    }
    #[test]
    fn pixel_ground_round_trip_is_metric() {
        let expected = (2.0, 0.35);
