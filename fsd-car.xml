            y: 0.0,
            a: 0.3,
            b: 0.2,
        }])
        .unwrap_err();
        assert!(err.contains("non-finite"));
    }
    #[test]
    fn obstacle_parameter_builder_rejects_bad_dimensions() {
        let obstacles = vec![
            动态障碍物 {
                x: 0.0,
                y: 0.0,
                a: 0.3,
                b: 0.2,
            },
            动态障碍物 {
                x: 1.0,
                y: 0.0,
                a: 0.3,
                b: 0.2,
            },
            动态障碍物 {
                x: 2.0,
                y: 0.0,
                a: 0.3,
                b: 0.2,
            },
            动态障碍物 {
                x: 3.0,
                y: 0.0,
