    "W": {
      "name": "Isaac world",
      "handedness": "right-handed",
      "axes": "x and y span the ground plane; z points up; yaw=0 faces +x; positive yaw is counter-clockwise about +z",
      "units": "m, rad"
    },
    "E": {
      "name": "ego/body",
      "handedness": "right-handed",
      "axes": "x forward, y left, z up",
      "world_to_ego": "x_e=dx*cos(yaw)+dy*sin(yaw); y_e=-dx*sin(yaw)+dy*cos(yaw)",
      "units": "m, rad"
    },
    "C": {
      "name": "OpenCV camera",
      "handedness": "right-handed",
      "axes": "x right, y down, z forward",
      "units": "pixel or m as declared by the payload"
    },
    "BEV": {
      "name": "ego-centered raster",
      "axes": "decreasing row is ego-forward; decreasing column is ego-left",
      "origin_cell": [95.5, 95.5],
      "shape": [192, 192],
      "meters_per_cell": 0.10416666666666667,
      "physical_extent_m": [20.0, 20.0]
    }
  },
